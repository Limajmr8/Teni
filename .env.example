# ============================================================
# BAZAR - Environment Variables
# Copy this file to .env.local in each app and fill in values
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Get from: https://app.supabase.com/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Server only - never expose

# ── Razorpay ──────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-here          # Server only
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here        # From Razorpay webhook settings

# ── Mapbox ────────────────────────────────────────────────
# Get from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiYmF6YXIiLCJhIjoiY...

# ── App URLs ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000               # Web buyer app
NEXT_PUBLIC_WAREHOUSE_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# ── Cloudinary (Image uploads) ────────────────────────────
# Get from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=bazar-unsigned    # Create an unsigned preset

# ── WhatsApp / Twilio (optional) ─────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Expo (Mobile) ─────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiYmF6YXIiLCJhIjoiY...
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
